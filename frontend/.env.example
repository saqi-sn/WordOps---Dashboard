# Copy to .env.local for local dev (not committed).

# API base used by the fetch client. Default '/api' (same-origin) works in prod.
VITE_API_URL=/api

# Dev-only: where Vite proxies /api during `npm run dev`.
# Point this at your WordOps server running the PHP backend.
VITE_API_PROXY=http://YOUR_SERVER_IP
