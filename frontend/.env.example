# Copy to .env.local for local dev (not committed).

# API entry. Query-string routing → defaults to /api/index.php (same-origin in prod).
VITE_API_URL=/api/index.php

# Dev-only: where Vite proxies /api during `npm run dev`.
# Point this at a WordOps server (or local php server) running the PHP backend.
VITE_API_PROXY=http://YOUR_SERVER_IP
